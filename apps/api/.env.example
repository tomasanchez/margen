# Margen API — example environment.
# Copy to .env and adjust per environment. Real .env is gitignored (never commit secrets).

# --- Database (DatabaseSettings, env_prefix DATABASE_) ---
# Async SQLAlchemy URL. Local default targets the docker-compose Postgres service.
DATABASE_URL=postgresql+asyncpg://margen-api:margen-api@localhost:5432/margen-api
# Supabase Cloud managed Postgres (ADR-091). Use the SESSION pooler (port 5432) with the
# asyncpg driver. Server-side secret only — never ship to the client (ADR-093). Example:
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Create the schema at startup. Keep false outside demos/tests; use Alembic (make migrate) instead.
DATABASE_AUTO_CREATE_SCHEMA=false

# --- API (ApplicationSettings, env_prefix FASTAPI_) ---
# Comma-separated allowed CORS origins (no quotes/brackets — dotenv would strip them).
# Defaults to the Vite dev origin. No wildcard. (ADR-006)
FASTAPI_BACKEND_CORS_ORIGINS=http://localhost:5173
# Enable verbose FastAPI logging in development only.
FASTAPI_DEBUG=false
# Machine-to-machine bearer token for the scheduled Monotributo capture (ADR-064). Empty = endpoint disabled (503).
FASTAPI_MONOTRIBUTO_CAPTURE_TOKEN=
# Supabase user id the M2M capture attributes the snapshot to (ADR-112). Unset = capture fails closed (503, later task).
# FASTAPI_MONOTRIBUTO_OWNER_ID=<supabase user uuid the scheduled capture computes for>

# --- Supabase auth (ApplicationSettings, env_prefix FASTAPI_) ---
# Non-secret Supabase Cloud verification config (ADR-091/092/093). The service-role key is
# intentionally NOT included here. Consumed by a JWKS auth dependency in a later task.
# Project base URL, e.g. https://<ref>.supabase.co
FASTAPI_SUPABASE_URL=
# JWKS endpoint exposing the project's asymmetric signing keys (ES256).
FASTAPI_SUPABASE_JWKS_URL=
# Expected token issuer (iss claim), e.g. https://<ref>.supabase.co/auth/v1
FASTAPI_SUPABASE_JWT_ISSUER=
# Expected token audience (aud claim). Supabase issues "authenticated" for signed-in users.
FASTAPI_SUPABASE_JWT_AUDIENCE=authenticated
