# Margen API — example environment.
# Copy to .env and adjust per environment. Real .env is gitignored (never commit secrets).

# --- Database (DatabaseSettings, env_prefix DATABASE_) ---
# Async SQLAlchemy URL. Local default targets the docker-compose Postgres service.
DATABASE_URL=postgresql+asyncpg://margen-api:margen-api@localhost:5432/margen-api
# Create the schema at startup. Keep false outside demos/tests; use Alembic (make migrate) instead.
DATABASE_AUTO_CREATE_SCHEMA=false

# --- API (ApplicationSettings, env_prefix FASTAPI_) ---
# CORS allow-list (JSON array). Defaults to the Vite dev origin. No wildcard. (ADR-006)
FASTAPI_BACKEND_CORS_ORIGINS=["http://localhost:5173"]
# Enable verbose FastAPI logging in development only.
FASTAPI_DEBUG=false
