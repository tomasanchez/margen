# Margen web — example environment configuration.
# Copy this file to `.env` and adjust values for your environment.
# Real `.env` files are gitignored (ADR-007). Never commit secrets.

# Base URL of the Margen backend API (ADR-006).
# Local default: the backend runs on port 8000.
VITE_API_BASE_URL=http://localhost:8000

# Supabase project URL (ADR-093). Find it in the Supabase dashboard
# under Project Settings -> API. Example: https://xxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/publishable key (ADR-093). Browser-safe — NEVER use the
# service-role key here. Project Settings -> API -> Project API keys.
VITE_SUPABASE_ANON_KEY=
